/****************************************************************************/
/*                                                                          */
/*              OMAPL138 ๏ฟฝ๏ฟฝ DSP C6748 ๏ฟฝฺด๏ฟฝีผ๏ฟฝ๏ฟฝ๏ฟฝไถจ๏ฟฝ๏ฟฝ                      */
/*                                                                          */
/*              2014๏ฟฝ๏ฟฝ05๏ฟฝ๏ฟฝ16๏ฟฝ๏ฟฝ                                              */
/*                                                                          */
/****************************************************************************/

MEMORY
{
#ifdef DSP_CORE
/****************************************************************************/
/*                                                                          */
/*              DSP ืจ๏ฟฝ๏ฟฝ๏ฟฝฺด๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ                                            */
/*                                                                          */
/****************************************************************************/
    DSPL2ROM     o = 0x00700000  l = 0x00100000  /* 1MB   L2 DSP ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ROM (DSP ROM Bootloader) */
    DSPL2RAM     o = 0x00800000  l = 0x00040000  /* 256kB L2 DSP ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
    DSPL1PRAM    o = 0x00E00000  l = 0x00008000  /* 32kB  L1 DSP ๏ฟฝ๏ฟฝ๏ฟฝุณ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
    DSPL1DRAM    o = 0x00F00000  l = 0x00008000  /* 32kB  L1 DSP ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
#endif

/****************************************************************************/
/*                                                                          */
/*              ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฺด๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ                                                */
/*                                                                          */
/****************************************************************************/
    SHDSPL2ROM   o = 0x11700000  l = 0x00100000  /* 1MB   L2 ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ROM */
    SHDSPL2RAM   o = 0x11800000  l = 0x00040000  /* 256KB L2 ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
    SHDSPL1PRAM  o = 0x11E00000  l = 0x00008000  /* 32KB  L1 ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝรณ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
    SHDSPL1DRAM  o = 0x11F00000  l = 0x00008000  /* 32KB  L1 ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */

    EMIFACS0     o = 0x40000000  l = 0x20000000  /* 512MB SDRAM (CS0) */
    EMIFACS2     o = 0x60000000  l = 0x02000000  /* 32MB  ๏ฟฝ์ฒฝ          (CS2) */
    EMIFACS3     o = 0x62000000  l = 0x02000000  /* 32MB  ๏ฟฝ์ฒฝ          (CS3) */
    EMIFACS4     o = 0x64000000  l = 0x02000000  /* 32MB  ๏ฟฝ์ฒฝ          (CS4) */
    EMIFACS5     o = 0x66000000  l = 0x02000000  /* 32MB  ๏ฟฝ์ฒฝ          (CS5) */

    SHRAM        o = 0x80000000  l = 0x00020000  /* 128KB ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
    DDR2         o = 0xC0001000  l = 0x08000000  /* 128MB  DDR2 ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ DSP */

	EntryPoint   o = 0xC0000000  l = 0x00000800  /* 2 KB  C ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฺต๏ฟฝ */
	Vector       o = 0xC0000800  l = 0x00000800  /* 2 KB  ๏ฟฝะถ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */

/****************************************************************************/
/*                                                                          */
/*              ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฺด๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ                                                */
/*                                                                          */
/****************************************************************************/
    SYSCFG0      o = 0x01C14000  l = 0x00001000  /* 4K    SYSCFG0 */
    uPP          o = 0x01E16000  l = 0x00001000  /* 4K    uPP */
    GPIO         o = 0x01E26000  l = 0x00001000  /* 4K    GPIO */
    McBSP1       o = 0x01D11000  l = 0x00000800  /* 2K    McBSP1 */

#ifndef DSP_CORE
/****************************************************************************/
/*                                                                          */
/*              ARM ืจ๏ฟฝ๏ฟฝ๏ฟฝฺด๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ                                            */
/*                                                                          */
/****************************************************************************/
    ARMROM       o = 0xFFFD0000  l = 0x00010000  /* 64kB  ARM ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ROM (ARM ROM Bootloader) */
    ARMRAM       o = 0xFFFF0000  l = 0x00002000  /* 8kB   ARM ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ RAM */
#endif
}

SECTIONS
{
    .text:_c_int00	>  EntryPoint 				 /* ๏ฟฝ๏ฟฝึด๏ฟฝะด๏ฟฝ๏ฟฝ๏ฟฝ C ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฺต๏ฟฝ*/
    .text			>  DDR2 				     /* ๏ฟฝ๏ฟฝึด๏ฟฝะด๏ฟฝ๏ฟฝ๏ฟฝ */
    .stack			>  DDR2 				     /* ๏ฟฝ๏ฟฝ๏ฟฝฯตอณีป */
    .bss			>  DDR2 				     /* ฮด๏ฟฝ๏ฟฝสผ๏ฟฝ๏ฟฝศซ๏ฟฝึผ๏ฟฝ๏ฟฝ๏ฟฝฬฌ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .cio			>  DDR2                      /* C ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    ".vectors"		>  Vector    				 /* ๏ฟฝะถ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .const			>  DDR2                      /* ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .data			>  DDR2                      /* ๏ฟฝัณ๏ฟฝสผ๏ฟฝ๏ฟฝศซ๏ฟฝึผ๏ฟฝ๏ฟฝ๏ฟฝฬฌ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .switch			>  DDR2                      /* ๏ฟฝ๏ฟฝืช๏ฟฝ๏ฟฝ */
    .sysmem			>  DDR2                      /* ๏ฟฝ๏ฟฝฬฌ๏ฟฝฺด๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .far			>  DDR2                      /* ิถ๏ฟฝ๏ฟฝศซ๏ฟฝึผ๏ฟฝ๏ฟฝ๏ฟฝฬฌ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */
    .args			>  DDR2
    .ppinfo			>  DDR2
    .ppdata			>  DDR2

    /* TI-ABI ๏ฟฝ๏ฟฝ COFF */
    .pinit			>  DDR2                      /* C++ ๏ฟฝแนน๏ฟฝ๏ฟฝ */
    .cinit			>  DDR2                      /* ๏ฟฝ๏ฟฝสผ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ */

    /* EABI */
    .binit			>  DDR2
    .init_array		>  DDR2
    .neardata		>  DDR2
    .fardata		>  DDR2
    .rodata			>  DDR2
    .c6xabi.exidx	>  DDR2
    .c6xabi.extab	>  DDR2

	/* DDR2 */
    .buffer			>  DDR2

	/* ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ  */
	.Reg_SYSCFG0	>  SYSCFG0
	.Reg_uPP		>  uPP
	.Reg_GPIO		>  GPIO
//	.Reg_McBSP1		>  McBSP1
/* ๆนๆๅธฆ SH ็ๅจๅฑๅฐๅๆ ๅฐ๏ผ */
    .l1d_data       >  SHDSPL1DRAM
    .l2_ram_data    >  SHDSPL2RAM
}
